# ───────────────────────────────────────────────────────────────────────────
# Keel Backend — environment. Copy to `.env` and fill secrets. NEVER commit .env.
# Every value here is read by app/config.py (pydantic-settings). No hardcoding.
# The app boots with these defaults; AI features need OPENAI_API_KEY set.
# ───────────────────────────────────────────────────────────────────────────

APP_ENV=local
DEBUG=true

# ---- Security (CHANGE THESE) ----
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=dev-only-change-me-please-use-a-long-random-string
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=30
BCRYPT_ROUNDS=12

# Comma-separated CORS origins (NO wildcards). The keel-UI dev server:
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- PostgreSQL ----
POSTGRES_USER=keel
POSTGRES_PASSWORD=keel
POSTGRES_DB=keel
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Async DSN used by the app; the sync DSN for Alembic is derived automatically.
DATABASE_URL=postgresql+asyncpg://keel:keel@postgres:5432/keel

# ---- Redis (Celery broker + result backend + rate limiter) ----
REDIS_URL=redis://redis:6379/0

# ---- Qdrant (vectors) ----
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# ---- Neo4j (graph) ----
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=keelneo4j

# ---- Object storage ----
STORAGE_BACKEND=s3                 # local | s3
STORAGE_LOCAL_PATH=./data/objects
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET=keel
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# ---- OpenAI / AI ----
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMS=1536
CHAT_MODEL_DEFAULT=gpt-4o-mini
EMBED_BATCH_SIZE=100
EMBED_MAX_RPM=3000                 # token-bucket rate limit for embeddings

# ---- Retrieval / chat ----
CHAT_TOP_K=10
MIN_SIMILARITY=0.65
CONTEXT_MAX_TOKENS=8000

# ---- Ingestion / Celery ----
CELERY_INGESTION_CONCURRENCY=4
INGESTION_TASK_TIMEOUT_SEC=1800    # 30 min
LARGE_FILE_TIMEOUT_SEC=5400        # 90 min for files > 100 MB
MAX_UPLOAD_BYTES=524288000         # 500 MB
MULTIPART_THRESHOLD_BYTES=10485760 # 10 MB
PART_SIZE_BYTES=5242880            # 5 MB

# ---- API ----
RATE_LIMIT_PER_MINUTE=100          # default per API key
LOGIN_MAX_ATTEMPTS=10
LOCKOUT_WINDOW_MIN=15
LOCKOUT_MIN=15
