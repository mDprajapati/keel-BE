# Version control
.git
.gitignore
.gitleaks.toml

# Documentation and project meta — not needed inside the image
# (README.md is kept: pyproject `readme = "README.md"` reads it during pip install)
docs
specs
CLAUDE.md
AGENTS.md
*.pdf
*.pptx

# CI/CD and tooling config
.github
.claude
.pre-commit-config.yaml

# Tests (not shipped in the runtime image)
**/tests

# Environment files — injected at runtime, never baked into image
.env
.env.*
!.env.example

# Local file-storage + logs (mounted at runtime)
**/var/uploads
**/data
data
*-data
logs

# Python cache and build artifacts (anywhere in tree)
**/__pycache__
**/*.pyc
**/*.pyo
**/*.egg-info
**/dist
**/build
**/.pytest_cache
**/.ruff_cache
**/.mypy_cache
**/.coverage
**/htmlcov
.venv
venv
