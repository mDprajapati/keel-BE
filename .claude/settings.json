{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(docker compose:*)",
      "Bash(docker:*)",
      "Bash(alembic:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(uvicorn:*)",
      "Bash(celery:*)",
      "Bash(python -m scripts.seed_admin)",
      "Read(./**)",
      "Edit(./**)",
      "Write(./**)"
    ],
    "deny": [
      "Bash(git push:* --force*)",
      "Bash(git push origin main*)",
      "Bash(git tag:*)",
      "Bash(git commit:* --no-verify*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/*credential*)",
      "Read(**/secrets/**)"
    ]
  }
}
